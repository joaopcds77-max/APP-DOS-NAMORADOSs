rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net - deny all other things by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation rules for surpresas collection
    match /surpresas/{surpresaId} {
      // Any recipient can retrieve a single surprise if they possess the exact ID in the url
      allow get: if isValidId(surpresaId);
      
      // Allow creation of surprises
      allow create: if (
        isValidId(surpresaId) &&
        isValidSurpresa(request.resource.data)
      );

      // System updates are normally handled by backend, but let's allow updating the declaracao_ia 
      // or falling back. For security, we allow updating only if we are adding the declaracao_ia
      allow update: if (
        isValidId(surpresaId) &&
        isValidSurpresa(request.resource.data) && (
          // Allow adding or updating the declaracao_ia specifically
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['declaracao_ia'])
        )
      );
    }

    // Global helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidSurpresa(data) {
      return (
        data.keys().hasAll(['partner1', 'partner2', 'startDate', 'musicTitle', 'musicArtist', 'history', 'photos', 'createdAt']) &&
        data.partner1 is string && data.partner1.size() > 0 && data.partner1.size() <= 100 &&
        data.partner2 is string && data.partner2.size() > 0 && data.partner2.size() <= 100 &&
        data.startDate is string && data.startDate.size() <= 50 &&
        data.musicTitle is string && data.musicTitle.size() <= 150 &&
        data.musicArtist is string && data.musicArtist.size() <= 150 &&
        (!data.keys().contains('musicPreviewUrl') || data.musicPreviewUrl is string) &&
        (!data.keys().contains('musicCoverUrl') || data.musicCoverUrl is string) &&
        data.history is string && data.history.size() <= 5000 &&
        data.photos is list && data.photos.size() <= 10 &&
        (data.photos.size() == 0 || data.photos[0] is string) &&
        data.createdAt is string
      );
    }
  }
}
